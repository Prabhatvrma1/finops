# ============================================================================
# Backend Environment Variables
# ============================================================================
# LEARNING: This is the .env.example file — a TEMPLATE showing what env vars
# your app needs. Developers copy this to .env and fill in real values.
# The actual .env file is in .gitignore and NEVER committed.
#
# WHY environment variables? This is 12-Factor App Principle #3 — "Config"
# Configuration that varies between environments (dev/prod) should be stored
# in environment variables, NOT in code. This way:
#   - Same code runs in dev and prod (different configs)
#   - Secrets aren't in your git history
#   - You can change config without redeploying code
# ============================================================================

# Server
NODE_ENV=development
PORT=4000

# Database (PostgreSQL connection string)
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://cloudcostiq:localdev123@localhost:5432/cloudcostiq

# Redis (for caching)
REDIS_URL=redis://localhost:6379

# JWT Authentication
# This is the secret key used to SIGN JWT tokens. If someone knows this,
# they can forge tokens and impersonate any user. Keep it LONG and RANDOM.
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=24h

# Mock Data Mode
# Set to "true" to use generated mock data instead of real cloud APIs.
# Great for development/demo when you don't have cloud credentials.
MOCK_DATA=true

# AWS Credentials (leave empty if using mock data)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Azure Credentials (leave empty if using mock data)
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# GCP Credentials (leave empty if using mock data)
GCP_PROJECT_ID=
GCP_KEY_FILE=

# OpenAI API Key (for AI Chat Advisor)
OPENAI_API_KEY=

# Logging Level (error, warn, info, debug)
LOG_LEVEL=info
